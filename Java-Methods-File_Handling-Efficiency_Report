import java.util.*;
import java.io.*;
public class efficiencyReport {
	public static void main(String [] args) {
		
		createFile();
		double []value = inputData();
		String report = "===EFFICIENCY REPORT ===\n\n";
		
		for(int i = 0; i< value.length; i++) {
			String status = levelStatus(value[i]);
			double efficiency = value[i];
			
			System.out.printf("Vehicle %d: %.2f%% km/L - %s\n", (i + 1), efficiency, status);
			
			report += String.format("Vehicle %d: %.2f%% km/L - %s\n", (i + 1), efficiency, status);
		}
		saveResults(report);
		System.out.println("File already saved to fuel_efficiency.txt");
		
		
	}
	public static double [] inputData() {
		Scanner scanner = new Scanner(System.in);
		
		System.out.println("How many vehicles? ");
		int count = scanner.nextInt();
		
		double []value = new double[count];
		
		System.out.println("Enter fuel efficiency (km/L: ");
		for(int i = 0; i < value.length; i++) {
			System.out.println("Vehicele "+(i + 1)+": ");
			value[i]= scanner.nextDouble();
		}
		return value;
	}
	public static String levelStatus(double value) {
		
		if(value >= 20) {
			return "Excellent Efficiency";
		}else if(value >= 10 && value <=19) {
			return "Normal Efficiency";
		}else {
			return "Low Efficiency";
		}
	}
	public static File createFile() {
		File file = new File("fuel_efficiency.txt");
		
		try {
			file.createNewFile();
		}catch(IOException e) {
			System.out.println("File already exists!");
		}
		return file;
	}
	public static void saveResults(String data){
		
		try {
			Writer writer = new FileWriter("fuel_efficiency.txt");
			writer.write(data);
			writer.close();
		}catch(IOException e) {
			System.out.println("An error has occured!");
		}
	}
}
