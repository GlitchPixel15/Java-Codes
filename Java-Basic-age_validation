import java.util.*;
public class age {
	public static void main(String [] args) {
		Scanner scanner = new Scanner(System.in);
		
	System.out.print("Enter your age:");	
	int age = scanner.nextInt();
	
	if(age == 18) {
		System.out.println("You are allowed");
	}
	else if(age >= 25) {
		System.out.println("You are allowed but pay extra $1");
	}
	else if(age >= 60) {
		System.out.println("You are allowed and nothing to pay :)");
	}
	else {
		System.out.println("You are not allowed invalid age!");
	}
		
	scanner.close();
	}
}
